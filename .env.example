# DeepSeek API（推荐，用于 AI 提取步骤）
# 注册地址: https://platform.deepseek.com
AI_API_KEY=sk-your-deepseek-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash

# 也可以使用 OpenAI API（备选方案）
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# Reddit API 凭证（在 https://www.reddit.com/prefs/apps 创建应用获取）
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=aram-insight-pipeline/1.0 (by /u/your_reddit_username)
