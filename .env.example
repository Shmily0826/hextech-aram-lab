# DeepSeek API（推荐，用于 AI 提取步骤）
# 注册地址: https://platform.deepseek.com
AI_API_KEY=sk-your-deepseek-api-key-here
OPENAI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-v4-flash

# 也可以使用 OpenAI API（备选方案）
# OPENAI_API_KEY=sk-your-openai-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o-mini

# Reddit API 凭证（在 https://www.reddit.com/prefs/apps 创建应用获取）
# 创建步骤:
#   1. 访问 https://www.reddit.com/prefs/apps
#   2. 点击 "create another app..."
#   3. 选择 "script" 类型
#   4. redirect uri 填 http://localhost:8080
#   5. 创建后复制 client_id（应用名下方那行）和 client_secret
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=script:hextech-aram-lab:v0.1 by u/YOUR_USERNAME
