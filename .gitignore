# 环境变量（包含 API 密钥）
.env

# Pipeline 输出数据（可能包含敏感内容）
pipeline/output/raw_reddit_posts.jsonl
pipeline/output/cleaned_items.jsonl
pipeline/output/manual_items.jsonl

# 数据修复过程中的备份文件
backups/
pipeline/output/*_backup*.json
pipeline/output/*_fixdupes_*.json
pipeline/output/*.en_backup

# Pipeline 中间产物（抓取/匹配原始数据，可重新生成）
pipeline/output/_debug_*.html
pipeline/output/augments_fixissues_*.json
pipeline/output/blitz_champion_augments_sample.json
pipeline/output/champion_augment_recommendations_sample.json

# 临时分析脚本（以 _ 开头）
scripts/_*.py

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# 系统文件
.DS_Store
Thumbs.db

.vercel
